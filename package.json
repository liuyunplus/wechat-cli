{
  "name": "wechat-cli",
  "version": "0.1.0",
  "description": "微信公众号 CLI - 面向 AI Agent 的命令行工具",
  "type": "module",
  "bin": {
    "wechat-cli": "./dist/bin/wechat-cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/wechat-cli.js",
    "dev": "tsx bin/wechat-cli.ts",
    "start": "node dist/bin/wechat-cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "wechat",
    "cli",
    "ai-agent",
    "公众号"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "form-data": "^4.0.0",
    "highlight.js": "^11.11.1",
    "inquirer": "^9.2.0",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
